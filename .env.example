# ============================================================
# Portal Magistério AGU — variáveis de ambiente
# Copie este arquivo para `.env` no servidor e preencha os valores.
# ============================================================

# ---- Feature flag (frontend) ----
# Quando "true", o botão "Entrar com gov.br" aparece na tela de login.
# Quando "false" (padrão), o botão fica oculto.
VITE_GOVBR_ENABLED=false

# ---- Login Único gov.br (OAuth2 / OIDC) ----
# Obtenha em https://acesso.gov.br (área do desenvolvedor).
# Use o provider de HOMOLOGAÇÃO até validar:
#   GOVBR_URI_PROVIDER=https://sso.staging.acesso.gov.br
# Em produção:
#   GOVBR_URI_PROVIDER=https://sso.acesso.gov.br
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
GOVBR_URI_PROVIDER=https://sso.staging.acesso.gov.br
GOVBR_REDIRECT_URI=https://portal.agu.gov.br/api/auth/govbr/callback
GOVBR_SCOPES=openid+email+profile+govbr_confiabilidades

# ---- MFA TOTP (login local / LDAP) ----
# Nome do emissor exibido no Google Authenticator / Authy.
MFA_ISSUER=Portal Magistério AGU
# Segredo usado para assinar/cifrar o JWT de sessão após validar o TOTP.
SESSION_JWT_SECRET=
