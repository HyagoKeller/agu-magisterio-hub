# ============================================================
# Portal Magistério AGU — variáveis de ambiente
# Copie este arquivo para `.env` no servidor e preencha os valores.
# ============================================================

# ---- Feature flags (frontend) ----
# Quando "true", o botão correspondente aparece na tela de login.
VITE_GOVBR_ENABLED=false
VITE_ENTRA_ENABLED=false

# ---- Login Único gov.br (OAuth2 / OIDC) ----
# Obtenha em https://acesso.gov.br (área do desenvolvedor).
# Homologação: GOVBR_URI_PROVIDER=https://sso.staging.acesso.gov.br
# Produção:    GOVBR_URI_PROVIDER=https://sso.acesso.gov.br
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
GOVBR_URI_PROVIDER=https://sso.staging.acesso.gov.br
GOVBR_REDIRECT_URI=https://portal.agu.gov.br/api/auth/govbr/callback
GOVBR_SCOPES=openid+email+profile+govbr_confiabilidades

# ---- Microsoft Entra ID / 365 (OIDC) ----
# Registre o app em https://entra.microsoft.com → App registrations.
# O MFA é aplicado pelas Conditional Access Policies do tenant.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=https://portal.agu.gov.br/api/auth/entra/callback
ENTRA_SCOPES=openid profile email offline_access

# ---- MFA TOTP (login local / LDAP) ----
# Nome do emissor exibido no Google Authenticator / Authy.
MFA_ISSUER=Portal Magistério AGU
# Segredo usado para assinar/cifrar o JWT de sessão após validar o TOTP.
SESSION_JWT_SECRET=
